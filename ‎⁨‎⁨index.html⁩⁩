<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">

<meta name="viewport"
content="width=device-width,
initial-scale=1.0">

<title>LAND ARAB</title>

<style>

body{
margin:0;
overflow:hidden;
background:black;
font-family:Arial;
touch-action:none;
}

canvas{
touch-action:none;
}

#menu{
position:fixed;
top:0;
left:0;
width:100%;
height:100%;
background:black;
display:flex;
justify-content:center;
align-items:center;
flex-direction:column;
z-index:100;
color:white;
}

#startGame{
padding:20px 40px;
font-size:30px;
background:red;
border:none;
border-radius:15px;
color:white;
}

#hud{
position:fixed;
top:10px;
left:10px;
background:rgba(0,0,0,0.5);
padding:10px;
border-radius:10px;
color:white;
z-index:10;
font-size:18px;
}

#shoot{
position:fixed;
bottom:40px;
right:30px;
width:90px;
height:90px;
border-radius:50%;
border:none;
background:red;
color:white;
font-size:30px;
z-index:20;
}

#jump{
position:fixed;
bottom:150px;
right:40px;
width:70px;
height:70px;
border-radius:50%;
border:none;
background:orange;
color:white;
font-size:25px;
z-index:20;
}

#joystick{
position:fixed;
bottom:40px;
left:30px;
width:120px;
height:120px;
border-radius:50%;
background:rgba(255,255,255,0.2);
z-index:20;
}

#miniMap{
position:fixed;
top:10px;
right:10px;
width:150px;
height:150px;
background:rgba(0,0,0,0.5);
border:2px solid white;
border-radius:10px;
z-index:20;
}

#fps{
position:fixed;
bottom:10px;
left:10px;
color:white;
z-index:20;
font-size:18px;
}

</style>
</head>

<body>

<div id="menu">

<h1 style="font-size:60px;">
LAND ARAB 🔥
</h1>

<p>Battle Royale Iraq</p>

<button id="startGame">
START
</button>

</div>

<div id="hud">
HP: 100<br>
Kills: 0<br>
Ammo: 30<br>
Gun: AK<br>
Zone: 40
</div>

<div id="miniMap"></div>

<div id="fps">
FPS: 60
</div>

<button id="shoot">🔥</button>

<button id="jump">⬆</button>

<div id="joystick"></div>

<script src="
https://cdn.jsdelivr.net/npm/
three@0.152.2/build/three.min.js
"></script>

<script>

//////////////////////////////
// SCENE
//////////////////////////////

const scene = new THREE.Scene();

scene.background =
new THREE.Color(0xd2b48c);

const camera =
new THREE.PerspectiveCamera(

75,

window.innerWidth /
window.innerHeight,

0.1,
1000

);

const renderer =
new THREE.WebGLRenderer({

antialias:true

});

renderer.setSize(
window.innerWidth,
window.innerHeight
);

renderer.shadowMap.enabled = true;

document.body.appendChild(
renderer.domElement
);

//////////////////////////////
// LIGHT
//////////////////////////////

const light =
new THREE.DirectionalLight(
0xffffff,
1
);

light.position.set(20,30,10);

scene.add(light);

//////////////////////////////
// GROUND
//////////////////////////////

const ground =
new THREE.Mesh(

new THREE.PlaneGeometry(
300,
300
),

new THREE.MeshStandardMaterial({
color:0xc2b280
})

);

ground.rotation.x =
-Math.PI/2;

scene.add(ground);

//////////////////////////////
// PLAYER
//////////////////////////////

const player =
new THREE.Mesh(

new THREE.BoxGeometry(1,2,1),

new THREE.MeshStandardMaterial({
color:0x00ff00
})

);

player.position.y = 1;

scene.add(player);

camera.position.set(
0,
5,
8
);

//////////////////////////////
// VARIABLES
//////////////////////////////

let hp = 100;
let kills = 0;
let ammo = 30;
let gunType = "AK";

let velocityY = 0;
let gravity = -0.01;

let moveX = 0;
let moveZ = 0;

let zoneSize = 40;

let driving = false;

//////////////////////////////
// BUILDINGS
//////////////////////////////

for(let i=0;i<20;i++){

const building =
new THREE.Mesh(

new THREE.BoxGeometry(

Math.random()*5+2,

Math.random()*10+5,

Math.random()*5+2

),

new THREE.MeshStandardMaterial({
color:0x777777
})

);

building.position.set(

Math.random()*150-75,

5,

Math.random()*150-75

);

scene.add(building);

}

//////////////////////////////
// ENEMIES
//////////////////////////////

const enemies=[];

for(let i=0;i<10;i++){

const enemy =
new THREE.Mesh(

new THREE.BoxGeometry(1,2,1),

new THREE.MeshStandardMaterial({
color:0xff0000
})

);

enemy.position.set(

Math.random()*80-40,

1,

Math.random()*-80

);

scene.add(enemy);

enemies.push(enemy);

}

//////////////////////////////
// CAR
//////////////////////////////

const car =
new THREE.Mesh(

new THREE.BoxGeometry(3,1,5),

new THREE.MeshStandardMaterial({
color:0x0000ff
})

);

car.position.set(
10,
1,
10
);

scene.add(car);

//////////////////////////////
// SAFE ZONE
//////////////////////////////

const zone =
new THREE.Mesh(

new THREE.RingGeometry(
40,
41,
64
),

new THREE.MeshBasicMaterial({

color:0x00ffff,
side:THREE.DoubleSide

})

);

zone.rotation.x =
-Math.PI/2;

scene.add(zone);

setInterval(()=>{

zoneSize -= 1;

zone.scale.set(
zoneSize/40,
zoneSize/40,
1
);

if(zoneSize < 10){

zoneSize = 40;

}

updateHUD();

},3000);

//////////////////////////////
// AIRDROP
//////////////////////////////

const airDrop =
new THREE.Mesh(

new THREE.BoxGeometry(2,2,2),

new THREE.MeshStandardMaterial({
color:0xff00ff
})

);

airDrop.position.set(
0,
20,
-30
);

scene.add(airDrop);

//////////////////////////////
// LOOT
//////////////////////////////

const lootBoxes=[];

for(let i=0;i<8;i++){

const loot =
new THREE.Mesh(

new THREE.BoxGeometry(1,1,1),

new THREE.MeshStandardMaterial({
color:0xffff00
})

);

loot.position.set(

Math.random()*80-40,

0.5,

Math.random()*80-40

);

scene.add(loot);

lootBoxes.push(loot);

}

//////////////////////////////
// START GAME
//////////////////////////////

document.getElementById(
"startGame"
).onclick=()=>{

document.getElementById(
"menu"
).style.display="none";

};

//////////////////////////////
// JOYSTICK
//////////////////////////////

const joystick =
document.getElementById(
"joystick"
);

joystick.addEventListener(
"touchmove",
(e)=>{

const touch = e.touches[0];

const rect =
joystick.getBoundingClientRect();

const x =
touch.clientX -
rect.left - 60;

const y =
touch.clientY -
rect.top - 60;

moveX = x * 0.01;
moveZ = y * 0.01;

}
);

joystick.addEventListener(
"touchend",
()=>{

moveX = 0;
moveZ = 0;

}
);

//////////////////////////////
// JUMP
//////////////////////////////

document.getElementById(
"jump"
).onclick=()=>{

if(player.position.y<=1.01){

velocityY = 0.25;

}

};

//////////////////////////////
// SHOOT
//////////////////////////////

document.getElementById(
"shoot"
).onclick=()=>{

if(ammo<=0){

ammo = 30;

updateHUD();

return;

}

ammo--;

const bullet =
new THREE.Mesh(

new THREE.SphereGeometry(0.2),

new THREE.MeshBasicMaterial({
color:0xffff00
})

);

bullet.position.copy(
player.position
);

scene.add(bullet);

function animateBullet(){

bullet.position.z -= 0.7;

if(bullet.position.z < -200){

scene.remove(bullet);

return;

}

for(let i=0;i<enemies.length;i++){

const enemy =
enemies[i];

if(
enemy &&
bullet.position.distanceTo(
enemy.position
)<1
){

createExplosion(

enemy.position.x,

enemy.position.y,

enemy.position.z

);

scene.remove(enemy);

scene.remove(bullet);

enemies.splice(i,1);

kills++;

updateHUD();

return;

}

}

requestAnimationFrame(
animateBullet
);

}

animateBullet();

updateHUD();

};

//////////////////////////////
// EXPLOSION
//////////////////////////////

function createExplosion(x,y,z){

const explosion =
new THREE.Mesh(

new THREE.SphereGeometry(2),

new THREE.MeshBasicMaterial({
color:0xff6600
})

);

explosion.position.set(
x,
y,
z
);

scene.add(explosion);

setTimeout(()=>{

scene.remove(explosion);

},300);

}

//////////////////////////////
// HUD
//////////////////////////////

function updateHUD(){

document.getElementById(
"hud"
).innerHTML=
`
HP: ${Math.floor(hp)}<br>
Kills: ${kills}<br>
Ammo: ${ammo}<br>
Gun: ${gunType}<br>
Zone: ${Math.floor(zoneSize)}
`;

}

//////////////////////////////
// LOOT
//////////////////////////////

function checkLoot(){

for(let i=0;i<lootBoxes.length;i++){

const loot =
lootBoxes[i];

if(
loot &&
player.position.distanceTo(
loot.position
)<2
){

scene.remove(loot);

lootBoxes.splice(i,1);

ammo += 10;

updateHUD();

break;

}

}

}

//////////////////////////////
// ZONE DAMAGE
//////////////////////////////

function checkZone(){

const dist = Math.sqrt(

player.position.x*
player.position.x +

player.position.z*
player.position.z

);

if(dist > zoneSize){

hp -= 0.05;

if(hp <= 0){

hp = 0;

document.getElementById(
"menu"
).style.display="flex";

}

updateHUD();

}

}

//////////////////////////////
// AIRDROP
//////////////////////////////

function updateAirDrop(){

if(airDrop.position.y>1){

airDrop.position.y -= 0.03;

}

}

//////////////////////////////
// ENEMIES AI
//////////////////////////////

function updateEnemies(){

enemies.forEach((enemy)=>{

if(enemy){

const dx =
player.position.x -
enemy.position.x;

const dz =
player.position.z -
enemy.position.z;

enemy.position.x += dx*0.001;

enemy.position.z += dz*0.001;

}

});

}

//////////////////////////////
// CAR
//////////////////////////////

document.addEventListener(
"keydown",
(e)=>{

if(e.key==="e"){

if(
player.position.distanceTo(
car.position
)<5
){

driving = !driving;

}

}

}
);

//////////////////////////////
// DAY NIGHT
//////////////////////////////

let day = true;

setInterval(()=>{

day = !day;

if(day){

scene.background =
new THREE.Color(0xd2b48c);

}else{

scene.background =
new THREE.Color(0x000022);

}

},15000);

//////////////////////////////
// FPS
//////////////////////////////

let lastTime =
performance.now();

function updateFPS(){

const now =
performance.now();

const fps =
Math.round(
1000/(now-lastTime)
);

lastTime = now;

document.getElementById(
"fps"
).innerHTML =
"FPS: " + fps;

}

//////////////////////////////
// ANIMATE
//////////////////////////////

function animate(){

requestAnimationFrame(
animate
);

checkLoot();

checkZone();

updateEnemies();

updateAirDrop();

updateFPS();

if(driving){

car.position.x += moveX;

car.position.z += moveZ;

player.position.copy(
car.position
);

player.position.y = 2;

}else{

player.position.x += moveX;

player.position.z += moveZ;

}

velocityY += gravity;

player.position.y += velocityY;

if(player.position.y < 1){

player.position.y = 1;

velocityY = 0;

}

camera.position.x =
player.position.x;

camera.position.z =
player.position.z + 8;

camera.lookAt(
player.position
);

renderer.render(
scene,
camera
);

}

updateHUD();

animate();

//////////////////////////////
// RESIZE
//////////////////////////////

window.addEventListener(
"resize",
()=>{

camera.aspect =
window.innerWidth /
window.innerHeight;

camera.updateProjectionMatrix();

renderer.setSize(
window.innerWidth,
window.innerHeight
);

}
);

</script>

</body>
</html>
